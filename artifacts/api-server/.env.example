# Copy this file to `.env` and fill in real values.
# The API server loads it via Node's --env-file flag:
#   node --env-file=.env --enable-source-maps ./dist/index.mjs

# Port the Express server listens on. 8080 matches the mobile app's local fallback.
PORT=8080

# HMAC secret for signing JWTs. Use a long random hex string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-hex-string

# PostgreSQL connection string.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/wahatna

# OpenRouteService API key for real road routing on the Fleet screen.
# Get a free key at https://openrouteservice.org/dev/#/signup
# Leave blank to fall back to straight-line distance estimates.
ORS_API_KEY=

# K2 Think V2 API key — powers hazard triage (selects the hazard type from the
# YOLO output, rates severity, and estimates the government resolution time).
# Paste your key here. Leave blank to fall back to the local rule-based agent.
K2THINK_API_KEY=

# Optional: URL of the local YOLO detection service (ml/detect_service.py).
# Defaults to http://127.0.0.1:8099 — only set this if you change the port.
# YOLO_SERVICE_URL=http://127.0.0.1:8099
